<!DOCTYPE html>
<html>
<head>
  <title>Edit Topic | IndoAge GPT</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
    body { background: #f8fafc; color: #1e293b; }
    .container { max-width: 1000px; margin: 40px auto; padding: 0 20px; }
    
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .header h1 { font-size: 28px; font-weight: 800; color: #0f172a; }
    .back-link { text-decoration: none; color: #6366f1; font-weight: 600; display: flex; align-items: center; gap: 5px; }
    
    .card { background: white; padding: 30px; border-radius: 16px; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); }
    
    .form-group { margin-bottom: 25px; }
    label { display: block; font-size: 14px; font-weight: 600; color: #64748b; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.025em; }
    
    input[type="text"], textarea {
      width: 100%; padding: 14px; border: 1px solid #e2e8f0; border-radius: 10px; 
      font-size: 16px; transition: all 0.2s; background: #f1f5f9;
    }
    
    input[type="text"]:focus, textarea:focus {
      outline: none; border-color: #6366f1; background: white; box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }
    
    textarea { min-height: 400px; resize: vertical; line-height: 1.6; font-family: 'Inter', sans-serif; }
    
    /* PREVIEW PANEL */
    .preview-panel {
      margin-top: 40px;
      padding: 40px;
      background: white;
      border-radius: 16px;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      border: 1px solid #e2e8f0;
    }
    
    .preview-header { margin-bottom: 30px; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; }
    .preview-header h2 { font-size: 20px; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; }
    
    .blog-preview-container { max-width: 800px; margin: auto; }
    .blog-title { font-size: 36px; font-weight: 800; line-height: 1.2; margin-bottom: 20px; color: #0f172a; }
    .blog-featured-image { width: 100%; border-radius: 12px; margin-bottom: 30px; }
    .blog-content { font-size: 18px; line-height: 1.8; color: #334155; }
    .blog-content h1, .blog-content h2, .blog-content h3 { margin: 30px 0 15px; color: #0f172a; }
    .blog-content p { margin-bottom: 20px; }
    .blog-content img { max-width: 100%; border-radius: 12px; height: auto; }
    
    .btn-save {
      background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
      color: white; border: none; padding: 14px 28px; border-radius: 10px;
      font-weight: 700; font-size: 16px; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.4);
    }
    
    .btn-save:hover { transform: translateY(-1px); box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.4); }
    
    .status-info { display: flex; gap: 20px; margin-top: 10px; font-size: 13px; color: #94a3b8; }
    .status-info b { color: #475569; }

    /* LOADING OVERLAY */
    #loader-overlay {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 9999;
    }

    .spinner {
      width: 60px; height: 60px;
      border: 5px solid #f3f3f3;
      border-top: 5px solid #6366f1;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin-bottom: 20px;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .loader-text {
      font-size: 20px;
      font-weight: 700;
      color: #1e293b;
    }
  </style>
</head>
<body>

<div id="loader-overlay">
  <div class="spinner"></div>
  <div class="loader-text">Updating WordPress Media & Content...</div>
</div>

<div class="container">
  <div class="header">
    <h1>Edit Content</h1>
    <a href="/" class="back-link">← Back to Dashboard</a>
  </div>

  <div class="card">
    <form id="edit-form" action="/update/<%= topic.id %>" method="POST">
      <div class="form-group">
        <label>Topic Reference</label>
        <div style="font-size: 18px; font-weight: 600; color: #475569;"><%= topic.topic %></div>
        <div class="status-info">
          <span>Keywords: <b><%= topic.keywords %></b></span>
          <span>Status: <b><%= topic.status %></b></span>
        </div>
      </div>

      <div class="form-group">
        <label>Featured Image URL</label>
        <input type="text" name="featuredImage" id="input-featured" value="<%= topic.featuredImage %>" placeholder="Featured Image URL" required>
      </div>

      <div class="form-group">
        <label>Article Image URL</label>
        <input type="text" name="articleImage" id="input-article" value="<%= topic.articleImage %>" placeholder="Article Image URL" required>
      </div>

      <div class="form-group">
        <label>Blog Title</label>
        <input type="text" name="title" id="input-title" value="<%= topic.title %>" placeholder="Enter SEO Title" required>
      </div>

      <div class="form-group">
        <label>Meta Description</label>
        <input type="text" name="metaDescription" id="input-meta" value="<%= topic.metaDescription %>" placeholder="Enter Meta Description" required>
      </div>

      <div class="form-group">
        <label>Article Content (HTML)</label>
        <textarea name="content" id="input-content" placeholder="Write or edit blog content here..." required><%= topic.content %></textarea>
      </div>

      <!-- LIVE PREVIEW -->
      <div class="preview-panel">
        <div class="preview-header">
          <h2>Live Preview</h2>
        </div>
        
        <div class="blog-preview-container">
          <h1 class="blog-title" id="preview-title" contenteditable="true"></h1>
          <img src="" alt="Featured Image" class="blog-featured-image" id="preview-featured">
          <div class="blog-content" id="preview-content" contenteditable="true"></div>
        </div>
      </div>

      <div style="display: flex; justify-content: center; margin-top: 30px; margin-bottom: 50px;">
        <button type="submit" class="btn-save" style="padding: 18px 60px; font-size: 18px;">Save Final Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
  const inputs = {
    title: document.getElementById('input-title'),
    content: document.getElementById('input-content'),
    featured: document.getElementById('input-featured'),
    article: document.getElementById('input-article')
  };

  const previews = {
    title: document.getElementById('preview-title'),
    content: document.getElementById('preview-content'),
    featured: document.getElementById('preview-featured')
  };

  let currentArticleUrl = inputs.article.value;

  // Sync from Input to Preview
  function updatePreview() {
    if (document.activeElement !== previews.title) {
      previews.title.innerText = inputs.title.value;
    }
    previews.featured.src = inputs.featured.value;
    
    if (document.activeElement !== previews.content) {
      previews.content.innerHTML = inputs.content.value;
    }
  }

  // Sync from Preview to Input
  function updateInput() {
    inputs.title.value = previews.title.innerText;
    inputs.content.value = previews.content.innerHTML;
  }

  // Auto-sync Article Image URL in Content
  function syncArticleImageInContent() {
    const newUrl = inputs.article.value;
    let content = inputs.content.value;
    
    // Create a temporary div to manipulate HTML
    const tempDiv = document.createElement('div');
    tempDiv.innerHTML = content;
    
    // 1. Try finding by class (for new topics)
    let img = tempDiv.querySelector('.article-image');
    
    // 2. Try finding by current URL (for older topics or if class is missing)
    if (!img) {
      img = tempDiv.querySelector(`img[src="${currentArticleUrl}"]`);
    }
    
    // 3. Fallback: try any image if there's only one
    if (!img) {
      const allImgs = tempDiv.querySelectorAll('img');
      if (allImgs.length === 1) img = allImgs[0];
    }
    
    if (img) {
      img.src = newUrl;
      inputs.content.value = tempDiv.innerHTML;
      currentArticleUrl = newUrl;
      updatePreview();
    } else {
      // Last resort: simple string replace if DOM search failed
      if (content.includes(currentArticleUrl)) {
        content = content.split(currentArticleUrl).join(newUrl);
        inputs.content.value = content;
        currentArticleUrl = newUrl;
        updatePreview();
      }
    }
  }

  // Listen for changes on Inputs
  inputs.title.addEventListener('input', updatePreview);
  inputs.content.addEventListener('input', updatePreview);
  inputs.featured.addEventListener('input', updatePreview);
  
  inputs.article.addEventListener('input', () => {
    syncArticleImageInContent();
  });

  // Listen for changes on Preview elements (Two-way sync)
  previews.title.addEventListener('input', updateInput);
  previews.content.addEventListener('input', updateInput);

  // Initial preview
  updatePreview();

  // Show loader on save
  document.getElementById('edit-form').addEventListener('submit', () => {
    document.getElementById('loader-overlay').style.display = 'flex';
  });
</script>

</body>
</html>
