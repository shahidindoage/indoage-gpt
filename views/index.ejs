<!DOCTYPE html>
<html>
<head>
  <title>IndoAge GPT</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Inter, Arial, sans-serif;
    }

    body {
      background: #f5f7fb;
      color: #1f2937;
    }

    .container {
      max-width: 1250px;
      margin: auto;
      padding: 30px;
    }

    /* HEADER */
    .header {
      margin-bottom: 20px;
    }

    .header h1 {
      font-size: 26px;
      font-weight: 700;
    }

    .header p {
      color: #6b7280;
      margin-top: 5px;
    }

    /* CARD */
    .card {
      background: white;
      padding: 18px;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
      margin-bottom: 20px;
    }

    /* FORM */
    .form {
      display: grid;
      grid-template-columns: 2fr 2fr 2fr auto;
      gap: 10px;
    }

    input {
      padding: 12px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      outline: none;
      font-size: 14px;
    }

    input:focus {
      border-color: #6366f1;
    }

    .btn {
      padding: 12px 16px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      font-size: 14px;
    }

    .btn-primary {
      background: #4f46e5;
      color: white;
    }

    .btn-primary:hover {
      background: #4338ca;
    }

    /* MESSAGES */
    .msg-success {
      color: #16a34a;
      margin-bottom: 10px;
      font-weight: 500;
    }

    .msg-error {
      color: #dc2626;
      margin-bottom: 10px;
      font-weight: 500;
    }

    /* TABLE CARD */
    .table-card {
      background: white;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead {
      background: #111827;
      color: white;
    }

    th, td {
      padding: 14px;
      text-align: left;
      font-size: 14px;
    }

    tbody tr {
      border-bottom: 1px solid #f1f5f9;
      transition: 0.2s;
    }

    tbody tr:hover {
      background: #f9fafb;
    }

    /* STATUS BADGE */
    .badge {
      padding: 5px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
      display: inline-block;
    }

    .Pending { background: #fef3c7; color: #92400e; }
    .Processing { background: #dbeafe; color: #1e40af; }
    .Published { background: #dcfce7; color: #166534; }
    .Failed { background: #fee2e2; color: #991b1b; }

    /* ACTION BUTTONS */
    .actions {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .btn-small {
      padding: 6px 10px;
      font-size: 12px;
      border-radius: 6px;
      border: none;
      cursor: pointer;
      font-weight: 600;
      width: stretch;
      text-align: center;
    }

    .publish {
      background: #2563eb;
      color: white;
    }

    .delete {
      background: #ef4444;
      color: white;
    }

    /* MOBILE */
    @media (max-width: 900px) {
      .form {
        grid-template-columns: 1fr;
      }

      table {
        font-size: 12px;
      }

      th, td {
        padding: 10px;
      }
    }

    /* LOADING OVERLAY */
    #loader-overlay {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(8px);
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 9999;
    }

    .spinner {
      width: 60px;
      height: 60px;
      border: 5px solid #f3f3f3;
      border-top: 5px solid #4f46e5;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin-bottom: 20px;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .loader-text {
      font-size: 18px;
      font-weight: 600;
      color: #1f2937;
    }

  </style>
  
  <!-- Flatpickr for Beautiful Date Selection -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

</head>

<body>

<div id="loader-overlay">
  <div class="spinner"></div>
  <div class="loader-text" id="loader-status">AI is generating content & uploading images...</div>
</div>

<div class="container">

  <!-- HEADER -->
  <div class="header">
    <h1>IndoAge GPT Dashboard</h1>
    <p>Manage topics, schedule posts, and auto-publish with AI</p>
  </div>

  <!-- FORM CARD -->
  <div class="card">

    <% if (message) { %>
      <div class="msg-success"><%= message %></div>
    <% } %>

    <% if (error) { %>
      <div class="msg-error"><%= error %></div>
    <% } %>

    <form class="form" action="/add-topic" method="POST">
      <input type="text" name="topic" placeholder="Enter Topic" required />
      <input type="text" name="keywords" placeholder="Keywords" required />
      <input type="text" id="date-display" placeholder="Select Publish Date" required />
      <input type="hidden" name="publishDate" id="date-picker-hidden">
      <button class="btn btn-primary" type="submit">Add Topic</button>
    </form>
  </div>

  <!-- TABLE -->
  <div class="table-card">
    <table>
      <thead>
        <tr>
          <th>Topic</th>
          <th>Keywords</th>
          <th>Publish Date</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>
        <% topics.forEach(t => { %>
          <tr>
            <td><strong><%= t.topic %></strong></td>
            <td><%= t.keywords %></td>
            <td>
              <% 
                const d = new Date(t.publishDate);
                const formattedDate = `${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}/${d.getFullYear()} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
              %>
              <%= formattedDate %>
            </td>
            <td>
              <span class="badge <%= t.status %>">
                <%= t.status %>
              </span>
            </td>
            <td>
              <div class="actions">
                <a href="/edit/<%= t.id %>" class="btn-small edit" style="background: #10b981; color: white; text-decoration: none; padding: 6px 10px; border-radius: 6px; font-weight: 600; font-size: 12px;">Edit</a>

                <form action="/publish/<%= t.id %>" method="POST">
                  <button class="btn-small publish">Publish Now</button>
                </form>

                <form action="/delete/<%= t.id %>" method="POST">
                  <button class="btn-small delete">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</div>

<script>
  const loaderOverlay = document.getElementById('loader-overlay');
  const loaderStatus = document.getElementById('loader-status');

  // Initialize Flatpickr
  flatpickr("#date-display", {
    enableTime: true,
    dateFormat: "m/d/Y H:i",
    minDate: "today",
    time_24hr: true,
    onChange: function(selectedDates, dateStr, instance) {
      if (selectedDates[0]) {
        // Send the timestamp (ms) to the server to avoid timezone confusion
        document.getElementById('date-picker-hidden').value = selectedDates[0].getTime();
      }
    }
  });

  // Handle Add Topic Form
  const addForm = document.querySelector('.form');
  if (addForm) {
    addForm.addEventListener('submit', () => {
      loaderStatus.innerText = "AI is generating content & uploading images...";
      loaderOverlay.style.display = 'flex';
    });
  }

  // Handle Publish/Delete Forms in Table
  document.querySelectorAll('.actions form').forEach(form => {
    form.addEventListener('submit', (e) => {
      const isPublish = form.querySelector('.publish') !== null;
      const isDelete = form.querySelector('.delete') !== null;
      
      if (isPublish) {
        loaderStatus.innerText = "Publishing to WordPress site...";
      } else if (isDelete) {
        loaderStatus.innerText = "Deleting from app & WordPress...";
      }
      
      loaderOverlay.style.display = 'flex';
    });
  });
</script>

</body>
</html>